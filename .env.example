AGENTGATE_HTTP_ADDR=:8080
AGENTGATE_ADMIN_ADDR=:9090
AGENTGATE_POSTGRES_DSN=postgres://agentgate:agentgate@localhost:5432/agentgate?sslmode=disable
AGENTGATE_REDIS_ADDR=localhost:6379
AGENTGATE_REDIS_PASSWORD=

AGENTGATE_JWT_SEED_HEX=
AGENTGATE_TOKEN_TTL=120s

AGENTGATE_VERIFIER=mock
# set AGENTGATE_VERIFIER=x402 for live Base Sepolia settlement (see docs/11-live-x402-base-sepolia.md)
AGENTGATE_NETWORK=base-sepolia
AGENTGATE_ASSET=0x036CbD53842c5426634e7929541eC2318f3dCF7e
AGENTGATE_ASSET_NAME=USDC
AGENTGATE_ASSET_VERSION=2
AGENTGATE_PAY_TO=0x209693Bc6afc0C5328bA36FaF03C514EF312287C
AGENTGATE_FACILITATOR_URL=https://x402.org/facilitator
AGENTGATE_MAX_TIMEOUT_SECS=120

AGENTGATE_ENFORCE=true
AGENTGATE_AUTH_TIMEOUT=1500ms
AGENTGATE_DEFAULT_RATE_RPM=120
AGENTGATE_ENV=dev

AGENTGATE_EDGE_SECRET=
AGENTGATE_BOT_RANGES_FILE=
AGENTGATE_ABUSE_THRESHOLD=5

# when set, a successful paid retry returns the ORIGIN resource itself (200 + body)
# instead of a token JSON: /verify emits X-Accel-Redirect=<prefix><resource> so nginx
# serves the origin, plus the reusable JWT in the X-AgentGate-Token header. Must match
# the internal nginx serve location (deploy/nginx/*.conf). Empty = return token JSON.
AGENTGATE_PAID_REDIRECT_PREFIX=/_agentgate_origin

# operator IP-range auto-refresh (recommended in prod so verification doesn't go stale)
# set an interval (e.g. 12h) to enable; empty/0 disables (uses hardcoded seed + BOT_RANGES_FILE only)
AGENTGATE_BOT_REFRESH_INTERVAL=
# optional: override the default provider source URLs (see deploy/bot-sources.example.json)
AGENTGATE_BOT_SOURCES_FILE=
